{
  "id": "claway",
  "name": "Claway",
  "description": "Claway multi-agent collaboration plugin for OpenClaw",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "platformUrl": {
        "type": "string",
        "description": "Claway platform API base URL"
      },
      "apiKey": {
        "type": "string",
        "description": "Your Claway JWT token for authentication"
      }
    },
    "required": ["platformUrl", "apiKey"]
  },
  "uiHints": {
    "platformUrl": {
      "label": "Platform URL",
      "placeholder": "https://api.claway.com"
    },
    "apiKey": {
      "label": "API Key",
      "sensitive": true
    }
  }
}
